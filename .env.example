# --- Seed & công cụ CLI (chỉ cần Postgres) ---
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
# Chạy: npm run db:seed

# --- Ứng dụng Next (Server Actions dùng Supabase REST API) ---
# Cần thêm 2 biến sau để web đọc/ghi DB qua supabase-js (lấy ở Dashboard → Settings → API):
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret

# --- Tuỳ chọn: PDF server-side (/api/pdf) trên VPS / Hostinger Node ---
# Cài Google Chrome hoặc Chromium trên máy chủ, rồi trỏ đường dẫn binary (nếu không có, app sẽ fallback in trình duyệt → Lưu thành PDF).
# CHROME_PATH=/usr/bin/google-chrome-stable
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome-stable
