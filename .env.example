# --- Seed & công cụ CLI (chỉ cần Postgres) ---
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
# Chạy: npm run db:seed

# --- Ứng dụng Next (Server Actions dùng Supabase REST API) ---
# Cần thêm 2 biến sau để web đọc/ghi DB qua supabase-js (lấy ở Dashboard → Settings → API):
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret

# --- PDF đẹp như Vercel: bắt buộc Chromium trên server (/api/pdf) ---
# Chỉ thực tế trên VPS (quyền root/SSH). Hostinger *shared* Node thường KHÔNG cài được Chrome → PDF xấu (html2pdf).
#
# Ubuntu/Debian (VPS):
#   sudo apt-get update && sudo apt-get install -y chromium-browser fonts-liberation libasound2 libatk-bridge2.0-0 libnss3 libx11-xcb1 libxcomposite1 libxdamage1 libxfixes3 libxrandr2 xdg-utils
#   (hoặc cài Google Chrome .deb — binary thường là /opt/google/chrome/chrome)
# Kiểm tra: command -v chromium-browser || command -v google-chrome-stable
#
# Trong panel Hostinger (hoặc .env production), đặt MỘT trong hai (đúng đường dẫn trên máy bạn):
# CHROME_PATH=/usr/bin/chromium-browser
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser
#
# Sau deploy: mở DevTools → Network → bấm Tải PDF → POST /api/pdf phải 200 và application/pdf (không fallback html2pdf).
